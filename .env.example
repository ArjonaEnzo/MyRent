# Supabase — find these in your project dashboard under Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose to the client

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HelloSign / Dropbox Sign — optional, enables digital signatures
# https://app.hellosign.com/api/reference
HELLOSIGN_API_KEY=your-hellosign-api-key
HELLOSIGN_CLIENT_ID=your-hellosign-client-id

# Mercado Pago — optional, enables online tenant payments (Checkout Pro)
# Credentials: https://www.mercadopago.com.ar/developers/panel/app → Credenciales
# Use TEST credentials for sandbox, PROD for production
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token
# Webhook secret: Tus integraciones → Webhooks → agregar URL de producción
# La clave secreta se genera automáticamente al crear el webhook
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# Vercel Cron — protects /api/cron/* endpoints
# Vercel auto-injects this in production; set manually for local testing
CRON_SECRET=your-cron-secret
